# API Configuration
VITE_API_URL=http://localhost:3000
VITE_APPSYNC_GRAPHQL_ENDPOINT=https://YOUR_APPSYNC_ID.appsync-api.us-east-1.amazonaws.com/graphql
VITE_APPSYNC_API_KEY=your-appsync-api-key

# Application Settings
VITE_APP_NAME=Field App
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_DEBUG=false
VITE_ENABLE_ANALYTICS=false

# Theme Configuration
VITE_PRIMARY_COLOR=#007bff
VITE_SECONDARY_COLOR=#6c757d
